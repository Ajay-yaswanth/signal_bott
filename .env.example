# PostgreSQL connection used by Prisma.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Authentication. Generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay server credentials. Plans are created server-side from the catalog.
RAZORPAY_KEY_ID="rzp_test_replace_me"
RAZORPAY_KEY_SECRET="replace-with-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="replace-with-webhook-secret"

# Private API key accepted by POST /api/signals/publish.
ULTRON_BOT_API_KEY="replace-with-a-long-random-bot-api-key"

# Private key accepted by the one-minute automated strategy scan endpoint.
ULTRON_STRATEGY_API_KEY="replace-with-a-long-random-strategy-api-key"

# Vercel sends CRON_SECRET automatically when invoking scheduled routes.
CRON_SECRET="replace-with-a-long-random-cron-secret"

# Pull provider used by the one-minute cron scan: twelvedata or binance.
MARKET_DATA_PROVIDER="twelvedata"

# TwelveData forex provider.
TWELVE_DATA_BASE_URL="https://api.twelvedata.com"
TWELVE_DATA_API_KEY="replace-with-twelvedata-api-key"
TWELVE_DATA_SYMBOL="XAU/USD"
TWELVE_DATA_POINT_SIZE="0.01"
TWELVE_DATA_SPREAD_POINTS="50"

# Binance crypto provider. Binance public market-data endpoints need no API key.
BINANCE_BASE_URL="https://api.binance.com"
BINANCE_SYMBOL="BTCUSDT"
BINANCE_POINT_SIZE="0.01"

# Optional TradingView webhook provider.
TRADINGVIEW_WEBHOOK_ENABLED="false"
TRADINGVIEW_WEBHOOK_SECRET="replace-with-long-tradingview-webhook-secret"

# Daily automated generation limits. Keep these within the product policy ranges.
ULTRON_MAX_NORMAL_SIGNALS_PER_DAY="25"
ULTRON_MAX_SNIPER_SIGNALS_PER_DAY="8"
