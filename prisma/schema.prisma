generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(USER)
  trialEndsAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  payments      Payment[]
  subscriptions Subscription[]
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  status                 SubscriptionStatus @default(TRIAL)
  razorpayCustomerId     String?
  razorpaySubscriptionId String?            @unique
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Signal {
  id         String          @id @default(cuid())
  symbol     String
  direction  SignalDirection
  entry      Decimal?        @db.Decimal(12, 2)
  stopLoss   Decimal?        @db.Decimal(12, 2)
  tp1        Decimal?        @db.Decimal(12, 2)
  tp2        Decimal?        @db.Decimal(12, 2)
  tp3        Decimal?        @db.Decimal(12, 2)
  confidence Int
  bias       String
  reason     String
  status     SignalStatus    @default(ACTIVE)
  result     SignalOutcome   @default(PENDING)
  points     Decimal?        @db.Decimal(10, 2)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  razorpayPaymentId String   @unique
  amount            Int
  currency          String   @default("INR")
  status            String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SignalDirection {
  BUY
  SELL
  WAIT
}

enum SignalStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum SignalOutcome {
  TP1
  TP2
  TP3
  SL
  BE
  PENDING

  @@map("SignalResult")
}
